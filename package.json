{
  "name": "@jiggai/kitchen-plugin-marketing",
  "version": "0.2.3",
  "description": "Marketing Suite plugin for ClawKitchen",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "db/migrations/",
    "scripts/kitchen-cli.js",
    "README.md"
  ],
  "bin": {
    "kitchen-plugin-marketing": "scripts/kitchen-cli.js"
  },
  "kitchenPlugin": {
    "id": "marketing",
    "name": "Marketing Suite",
    "teamTypes": [
      "marketing-team",
      "claw-marketing-team"
    ],
    "tabs": [
      {
        "id": "content-library",
        "label": "Content Library",
        "icon": "library",
        "bundle": "./dist/tabs/content-library.js"
      },
      {
        "id": "content-calendar",
        "label": "Content Calendar",
        "icon": "calendar",
        "bundle": "./dist/tabs/content-calendar.js"
      },
      {
        "id": "analytics",
        "label": "Analytics",
        "icon": "chart",
        "bundle": "./dist/tabs/analytics.js"
      },
      {
        "id": "accounts",
        "label": "Accounts",
        "icon": "users",
        "bundle": "./dist/tabs/accounts.js"
      }
    ],
    "apiRoutes": "./dist/api/routes.js",
    "migrations": "./db/migrations"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "node scripts/dev.js",
    "db:generate": "drizzle-kit generate:sqlite",
    "db:migrate": "drizzle-kit push:sqlite",
    "db:studio": "drizzle-kit studio",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.5",
    "drizzle-orm": "^0.38.0",
    "express": "^4.18.2",
    "multer": "^1.4.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.20.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.0.0"
  }
}
